STAKING_VAULT_ADDRESS=
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=

# Agent staking amounts (ETH)
AUDITOR_STAKE=0.000005
TRANSLATOR_STAKE=0.000003
ANALYST_STAKE=0.000008
