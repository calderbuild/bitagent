# Facilitator private key (for x402 payment settlement)
FACILITATOR_KEY=0x...

# Agent private keys
AGENT_AUDITOR_KEY=0x...
AGENT_TRANSLATOR_KEY=0x...
AGENT_ANALYST_KEY=0x...
AGENT_ORCHESTRATOR_KEY=0x...

# Client private key
